# =========================
# XHS Search
# =========================
# Required for signed request mode (or keep empty and use Playwright mode)
XHS_X_S=
XHS_X_S_COMMON=
XHS_X_T=

# Optional trace ids (auto generated if empty)
XHS_X_B3_TRACEID=
XHS_X_XRAY_TRACEID=

# Optional cookie override
XHS_COOKIE=

# Playwright behavior: 1=true, 0=false
XHS_USE_PLAYWRIGHT=1
# Allow unsigned fallback request (not recommended, may return 406)
XHS_ALLOW_UNSIGNED=0


# =========================
# Feishu / Bitable Upload
# =========================
# Feishu app credentials (for fetching tenant_access_token)
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Bitable target
FEISHU_BITABLE_APP_TOKEN=
FEISHU_BITABLE_TABLE_ID=
# 每次上传是否自动新建多维表（1/0）
FEISHU_CREATE_NEW_APP_EACH_UPLOAD=0
# 自动新建多维表时可选目录 token
FEISHU_BITABLE_FOLDER_TOKEN=

# Optional callback URL after upload done (leave empty to skip callback)
FEISHU_CALLBACK_URL=


# =========================
# LLM Streaming Gateway
# =========================
# DeepSeek API key (required for /chat/stream)
DEEPSEEK_API_KEY=sk-ad460dc918384243bc93ce028c0570b8
# Optional model override
DEEPSEEK_MODEL=deepseek-chat
# Optional n8n preprocess webhook (quick/non-blocking tasks only)
N8N_PREPROCESS_WEBHOOK_URL=
# Optional n8n postprocess webhook (async fire-and-forget)
N8N_POSTPROCESS_WEBHOOK_URL=
