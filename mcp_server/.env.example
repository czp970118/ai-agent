# Docker Compose: mcp 服务通过 compose.yml 的 env_file 加载本文件。
# 复制为 mcp_server/.env 后填写真实值（勿提交 git）。

# =========================
# LLM
# =========================
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# =========================
# Image Generation (optional)
# =========================
DASHSCOPE_API_KEY=
DASHSCOPE_IMAGE_SIZE=1024*1536

# =========================
# Chat Memory SQLite (optional)
# =========================
# CHAT_MEMORY_SQLITE_PATH=/app/mcp_server/data/chat_memory.db

# =========================
# XHS Scheduler
# =========================
XHS_SCHEDULER_ENABLED=1
XHS_SCHEDULER_TICK_SECONDS=20
XHS_PER_QUERY_PAGE_SIZE=20
XHS_COMBO_REPEAT_MIN=2
XHS_COMBO_REPEAT_MAX=3
XHS_TOPIC_BATCH_SIZE=2
XHS_REPEAT_GAP_SECONDS=1.0
XHS_SORT=general

# =========================
# XHS Search / Poll
# =========================
XHS_POLL_COUNT=2
XHS_POLL_INTERVAL_SECONDS=1.0
XHS_SEARCH_TIMEOUT_SECONDS=15.0
XHS_PLAN_TIMEOUT_SECONDS=60
XHS_ENABLE_REQUIREMENT_QUERIES=0
XHS_QUERY_PARALLEL=0
XHS_QUERY_GAP_SECONDS=0.6
XHS_PERSIST_SEARCH_JSON=0

# =========================
# XHS Playwright
# =========================
XHS_STORAGE_STATE=server/xhs/xhs_storage_state.json
XHS_PLAYWRIGHT_HEADLESS=1
# XHS_CHROMIUM_CHANNEL=chrome
# XHS_USE_SYSTEM_CHROME=1

# =========================
# Shared SQLite (optional)
# =========================
# XHS_SQLITE_PATH=/app/mcp_server/data/xhs_cache.db

# =========================
# SMTP Digest Email (optional)
# =========================
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_TO=
SMTP_SSL=1

# =========================
# Runtime env hints (optional)
# =========================
# APP_ENV=production
# ENV=production
# NODE_ENV=production

# =========================
# QCC Search (optional)
# =========================
QCC_STORAGE_STATE=server/qcc/qcc_storage_state.json
QCC_PLAYWRIGHT_HEADLESS=1
QCC_SEARCH_URL=https://www.qcc.com/api/search/searchMulti
QCC_X_PID=
QCC_DYNAMIC_HEADER_NAME=
QCC_DYNAMIC_HEADER_VALUE=
QCC_FILTER=
QCC_SEARCH_INDEX=multicondition
