FROM python:3.12-slim

WORKDIR /app/mcp_server

# Optional Playwright download host override.
ARG PLAYWRIGHT_DOWNLOAD_HOST=
ARG APT_MIRROR=mirrors.aliyun.com
ENV PLAYWRIGHT_DOWNLOAD_CONNECTION_TIMEOUT=120000

# Install Playwright runtime dependencies once at build time.
RUN sed -i "s|deb.debian.org|${APT_MIRROR}|g; s|security.debian.org|${APT_MIRROR}|g" /etc/apt/sources.list.d/debian.sources \
    && apt-get update && apt-get install -y --no-install-recommends \
    libglib2.0-0 \
    libnss3 \
    libnspr4 \
    libdbus-1-3 \
    libatk1.0-0 \
    libatk-bridge2.0-0 \
    libcups2 \
    libdrm2 \
    libxkbcommon0 \
    libxcomposite1 \
    libxdamage1 \
    libxfixes3 \
    libxrandr2 \
    libgbm1 \
    libasound2 \
    libatspi2.0-0 \
    libxshmfence1 \
    libgtk-3-0 \
    libx11-6 \
    libx11-xcb1 \
    libxcb1 \
    libxext6 \
    libxrender1 \
    libxi6 \
    libxss1 \
    libxtst6 \
    libpango-1.0-0 \
    libcairo2 \
    libfontconfig1 \
    libfreetype6 \
    ca-certificates \
    fonts-liberation \
    && rm -rf /var/lib/apt/lists/*

RUN python -m pip install --no-cache-dir -i https://pypi.tuna.tsinghua.edu.cn/simple --retries 10 --timeout 120 uv

COPY mcp_server/ /app/mcp_server/

RUN uv sync && if [ -n "$PLAYWRIGHT_DOWNLOAD_HOST" ]; then PLAYWRIGHT_DOWNLOAD_HOST="$PLAYWRIGHT_DOWNLOAD_HOST" uv run playwright install chromium; else uv run playwright install chromium; fi
