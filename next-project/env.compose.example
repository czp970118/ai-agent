# Docker Compose 的 next 服务通过 compose.yml 的 env_file 加载 env.compose（勿提交 env.compose）。
# 首次: cp env.compose.example env.compose，再按需改 NEXT_PUBLIC_MCP_SERVER_URL。
# 生产 HTTPS + Nginx 反代时填公网域名（与证书一致），勿带端口。

NEXT_PUBLIC_MCP_SERVER_URL=https://www.diandeng.online
NODE_ENV=production
NODE_OPTIONS=--max-old-space-size=1024
